{
  "expo": {
    "name": "Lunaria",
    "slug": "lunaria",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/moon_icon.png",
    "scheme": "fastshot",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/moon_icon.png",
        "backgroundColor": "#060818"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nimbus.lunaria"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/moon_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/moon_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#060818"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": ""
    },
    "owner": "nimbus1958",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d0290d23-5f47-4d02-a8a9-af0055260a71"
      }
    }
  }
}